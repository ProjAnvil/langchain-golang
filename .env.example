# langchain-golang integration test configuration.
#
# Copy this file to `.env`, fill in real values, then run:
#   make test-integration
#
# `.env` is gitignored — never commit real keys.
# All providers are optional: a test is skipped unless its *_ENABLED=1,
# so you can enable just the providers you have credentials for.
#
# The base URLs point at the official endpoints by default. Replace them with
# any OpenAI-compatible / Anthropic-compatible endpoint (proxy, gateway,
# self-hosted, etc.).

# --- OpenAI-compatible provider (any endpoint speaking the OpenAI chat API) ---
# BASE_URL must include the /v1 suffix (the partner appends /responses or /chat).
OPENAI_ENABLED=0
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Anthropic-compatible provider (any endpoint speaking /v1/messages) ---
# BASE_URL must include the /v1 suffix (the partner appends /messages).
ANTHROPIC_ENABLED=0
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
